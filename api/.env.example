# SocialAI Manager - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=SocialAI Manager
ENVIRONMENT=development
DEBUG=true

# 数据库配置
POSTGRES_USER=socialai
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=socialai_dev
DATABASE_URL=postgresql://socialai:your_secure_password_here@localhost:5432/socialai_dev

# JWT配置
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI模型配置 (使用MiniMax)
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_MODEL=MiniMax-M2.5

# 社交媒体API配置 (MVP阶段: 微信 + LinkedIn)

# 微信配置
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
WECHAT_TOKEN=your-wechat-token

# LinkedIn配置
LINKEDIN_API_KEY=your-linkedin-api-key
LINKEDIN_API_SECRET=your-linkedin-api-secret

# 钉钉配置
DINGTALK_APP_KEY=your-dingtalk-app-key
DINGTALK_APP_SECRET=your-dingtalk-app-secret
DINGTALK_AGENT_ID=your-dingtalk-agent-id

# 企业微信配置
WECOM_CORP_ID=your-wecom-corp-id
WECOM_CORP_SECRET=your-wecom-corp-secret
WECOM_AGENT_ID=your-wecom-agent-id

# 后续扩展:
# TWITTER_API_KEY=your-twitter-api-key
# TWITTER_API_SECRET=your-twitter-api-secret

# Redis配置
REDIS_URL=redis://localhost:6379

# Celery配置
CELERY_BROKER_URL=redis://localhost:6379
CELERY_RESULT_BACKEND=redis://localhost:6379
